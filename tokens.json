            "$value": "#8bb8ff",
            "$description": "Primary brand color"
        },
        "primary-darker": {
            "$type": "color",
            "$value": "#5b92f6"
        },
        "secondary": {
            "$type": "color",
            "$value": "#86184f",
            "$description": "Secondary brand color"
        },
        "tertiary": {
            "$type": "color",
            "$value": "#d4e5a2",
            "$description": "Tertiary brand color - accent"
        },
        "white": {
            "$type": "color",
            "$value": "#ffffff"
        },
        "background-primary": {
            "$type": "color",
            "$value": "#8bb8ff",
            "$description": "Primary background"
        },
        "text-primary": {
            "$type": "color",
            "$value": "#86185f",
