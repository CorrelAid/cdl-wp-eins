    "fluid": {
        "from-screen": {
            "$type": "number",
            "$value": 400,
            "$description": "Fluid scaling starts at this viewport width (px)"
        },
        "to-screen": {
            "$type": "number",
            "$value": 1200,
            "$description": "Fluid scaling ends at this viewport width (px)"
        },
        "root-font-size": {
            "$type": "number",
            "$value": 16,
            "$description": "Root font size in px — used to compute rem-based clamp values"
        }
    },
    "fontWeight": {
        "light": {
            "$type": "number",
            "$value": 300,
            "$description": "Light weight"
        },
        "normal": {
            "$type": "number",
            "$value": 400,
            "$description": "Normal/regular weight"
        },
        "medium": {
            "$type": "number",
            "$value": 500,
            "$description": "Medium weight"
        },
        "semibold": {
            "$type": "number",
            "$value": 600,
            "$description": "Semibold weight"
        },
        "bold": {
            "$type": "number",
            "$value": 700,
            "$description": "Bold weight"
        }
    },
    "lineHeight": {
        "tight": {
            "$type": "number",
            "$value": 1.15,
            "$description": "Large headings (h1)"
        },
        "snug": {
            "$type": "number",
            "$value": 1.25,
            "$description": "Headings (h2, h3, h4)"
        },
        "normal": {
            "$type": "number",
            "$value": 1.5,
            "$description": "Code, lists, compact text"
        },
        "relaxed": {
            "$type": "number",
            "$value": 1.6,
            "$description": "Body text, blockquotes"
        },
        "loose": {
            "$type": "number",
            "$value": 1.75,
            "$description": "Spacious reading"
        }
    },
    "letterSpacing": {
        "tighter": {
            "$type": "string",
            "$value": "-0.02em",
            "$description": "Tight tracking for large headings"
        },
        "tight": {
            "$type": "string",
            "$value": "-0.01em",
            "$description": "Slightly tight for medium headings"
        },
        "normal": {
            "$type": "string",
            "$value": "0em",
            "$description": "Default tracking"
        },
        "wide": {
            "$type": "string",
            "$value": "0.02em",
            "$description": "Slightly wide for small text"
        },
        "wider": {
            "$type": "string",
            "$value": "0.04em",
            "$description": "Wide tracking for uppercase labels"
        }
    },
    "fontFamily": {
        "heading": {
            "$type": "fontFamily",
            "$value": [
                "PP Fraktion Sans",
                "-apple-system",
                "BlinkMacSystemFont",
                "Segoe UI",
                "sans-serif"
            ],
            "$description": "Heading typeface"
        },
        "body": {
            "$type": "fontFamily",
            "$value": [
                "Inter",
                "-apple-system",
                "BlinkMacSystemFont",
                "Segoe UI",
                "Oxygen",
                "Ubuntu",
                "Cantarell",
                "sans-serif"
            ],
            "$description": "Body typeface"
        },
        "mono": {
            "$type": "fontFamily",
            "$value": [
                "PP Fraktion Mono",
                "ui-monospace",
                "Cascadia Code",
                "Source Code Pro",
                "Menlo",
                "Consolas",
                "monospace"
            ],
            "$description": "Monospace typeface"
