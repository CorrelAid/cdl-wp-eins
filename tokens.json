{
    "color": {
        "primary": {
            "$type": "color",
            "$value": "#8bb8ff",
            "$description": "Primary brand color"
        },
        "primary-darker": {
            "$type": "color",
            "$value": "#5b92f6"
        },
        "secondary": {
            "$type": "color",
            "$value": "#86184f",
            "$description": "Secondary brand color"
        },
        "tertiary": {
            "$type": "color",
            "$value": "#d4e5a2",
            "$description": "Tertiary brand color - accent"
        },
        "white": {
            "$type": "color",
            "$value": "#ffffff"
        },
        "background": {
            "primary": {
                "$type": "color",
                "$value": "#8bb8ff",
                "$description": "Primary background"
            }
        },
        "text": {
            "primary": {
                "$type": "color",
                "$value": "#86185f",
                "$description": "Primary text color (text color on primary color)"
            },
            "secondary": {
                "$type": "color",
                "$value": "#ffffff",
                "$description": "Text color on secondary color"
            }
        }
    },
    "dimension": {
        "spacing": {
            "xs": {
                "$type": "dimension",
                "$value": "0.75rem",
                "$description": "0.75rem spacing"
            },
            "sm": {
                "$type": "dimension",
                "$value": "1rem",
                "$description": "1rem spacing"
            },
            "md": {
                "$type": "dimension",
                "$value": "1.5rem",
                "$description": "1.5rem spacing"
            },
            "lg": {
                "$type": "dimension",
                "$value": "2rem",
                "$description": "2rem spacing"
            }
        },
        "border": {
            "width": {
                "$type": "dimension",
                "$value": "1.5px"
            }
        },
        "table": {
            "padding": {
                "$type": "dimension",
                "$value": "0.8rem"
            },
            "max-width": {
                "$type": "dimension",
                "$value": "1000px"
            }
        },
        "content": {
            "max-width": {
                "$type": "dimension",
                "$value": "60rem",
                "$description": "Max width for readable content"
            }
        },
        "font-size": {
            "base": {
                "$type": "dimension",
                "$value": "16px",
                "$description": "Base font size"
            },
            "body": {
                "min": {
                    "$type": "dimension",
                    "$value": "16px"
                },
                "max": {
                    "$type": "dimension",
                    "$value": "17px"
                }
            },
            "h1": {
                "min": {
                    "$type": "dimension",
                    "$value": "30px"
                },
                "max": {
                    "$type": "dimension",
                    "$value": "40px"
                }
            },
            "h2": {
                "min": {
                    "$type": "dimension",
                    "$value": "24px"
                },
                "max": {
                    "$type": "dimension",
                    "$value": "30px"
                }
            },
            "h3": {
                "min": {
                    "$type": "dimension",
                    "$value": "20px"
                },
                "max": {
                    "$type": "dimension",
                    "$value": "24px"
                }
            },
            "small": {
                "min": {
                    "$type": "dimension",
                    "$value": "15px"
                },
                "max": {
                    "$type": "dimension",
                    "$value": "18px"
                }
            }
        }
    },
    "typography": {
        "body": {
            "$type": "typography",
            "$value": {
                "fontFamily": ["Inter", "sans-serif"],
                "fontSize": "clamp(16px, 1rem + 0.5vw, 17px)",
                "fontWeight": 400,
                "lineHeight": 1.6
            }
        },
        "heading": {
            "h1": {
                "$type": "typography",
                "$value": {
                    "fontFamily": ["PP Fraktion Sans", "sans-serif"],
                    "fontSize": "clamp(30px, 2rem + 2vw, 40px)",
                    "fontWeight": 700,
                    "lineHeight": 1.2
                }
            },
            "h2": {
                "$type": "typography",
                "$value": {
                    "fontFamily": ["PP Fraktion Sans", "sans-serif"],
                    "fontSize": "clamp(24px, 1.625rem + 1vw, 30px)",
                    "fontWeight": 700,
                    "lineHeight": 1.2
                }
            },
            "h3": {
                "$type": "typography",
                "$value": {
                    "fontFamily": ["PP Fraktion Sans", "sans-serif"],
                    "fontSize": "clamp(20px, 1.375rem + 0.5vw, 24px)",
                    "fontWeight": 700,
                    "lineHeight": 1.2
                }
            }
        },
        "small": {
            "$type": "typography",
            "$value": {
                "fontFamily": ["PP Fraktion Sans", "sans-serif"],
                "fontSize": "clamp(15px, 0.9375rem + 0.5vw, 18px)",
                "fontWeight": 300,
                "lineHeight": 1.6
            }
        },
        "mono": {
            "$type": "typography",
            "$value": {
                "fontFamily": ["PP Fraktion Mono", "monospace"],
                "fontSize": "clamp(14px, 0.875rem + 0.5vw, 16px)",
                "fontWeight": 400,
                "lineHeight": 1.5
            }
        }
    }
}