        },
        "border-width": {
            "$type": "dimension",
            "$value": "1.5px"
        },
        "table-padding": {
            "$type": "dimension",
            "$value": "0.8rem"
        },
        "table-max-width": {
            "$type": "dimension",
            "$value": "1000px"
        }
    },
    "spacing": {
        "2xs": {
            "$type": "dimension",
            "$value": "0.25rem",
