---
import Layout from "@layouts/Layout.astro";
import Hardhat from "@lib/svg/hardhat.svg";
import TitleLine from "@components/TitleLine.svelte";
import SurveyPhases from "@components/SurveyPhases.svelte";
import { getCollection } from "astro:content";
import toc from "@lib/toc.json";

const allPages = await getCollection("pages");
const pageMap = Object.fromEntries(allPages.map(page => [page.id, page]));

// Build phases from toc sections
const phases = toc.sections
	.filter((s): s is { label: string; children: string[] } => typeof s === 'object')
	.map(section => ({
		id: section.children[0].replace(/-einleitung$/, ''),
		label: section.label,
		href: '/' + section.children[0],
	}));

// Build knowledge markers from toc sections (skip intro pages + excluded slugs)
const knowledgeMarkers = toc.sections
	.filter((s): s is { label: string; children: string[]; excludeFromGraphic?: string[] } => typeof s === 'object')
	.flatMap((section, phaseIndex) => {
		const exclude = section.excludeFromGraphic || [];
		return section.children
			.slice(1) // skip intro page
			.filter(slug => !exclude.includes(slug))
			.map(slug => ({
				label: pageMap[slug]?.data.tocTitle || slug,
				type: 'knowledge' as const,
				href: '/' + slug,
				phase: phaseIndex,
			}));
	});

// Spanning markers (compute grid rows from phase indices)
const spanningMarkers = toc.spanning.map(s => ({
	label: s.label,
	type: 'knowledge' as const,
	href: s.href,
	startRow: s.startPhase * 2 + 1,
	endRow: s.endPhase * 2 + 2,
	column: s.column,
}));

// Tool markers link to anchor on the tools page
const toolMarkers = toc.tools.map(t => ({ ...t, href: `/tools#${t.id}` }));

const markers = [...spanningMarkers, ...knowledgeMarkers, ...toolMarkers];
---

<Layout line="false">
	<body>
		<div class="logo-container">
			<Hardhat />
		</div>
		<section>
			<p>
				Wilkommen auf der Dokumentationseite der Ergebnisse aus der
				ersten Werkstattbox des <a href="https://civic-data.de"
					>Civic Data Labs</a
				>. Werkstattboxen sind ein Format, in dem wir uns im über einen
				Zeitraum von 2-3 Monaten mit einem Thema beschäftigen, bei dem
				wir indentifiziert haben, dass es dort in der Zivilgesellschaft
				an Wissen und Tools fehlt. Das Ergebnis von Werkstattboxen sind
				unter anderem strukturierte Wissenssammlungen in Form von
				Websites, aber auch Open Source Code und Apps die wir als Tools auf
				diesen Websites präsentieren. Das Thema dieser Werkstattbox sind
				Online-Umfragen.
			</p>
			<p>
				Online-Umfragen sind eine wichtige Methode zur Erhebung von
				Daten, die auch in der Zivilgesellschaft für vielfältige Zwecke
				eingesetzt werden kann. Als Civic Data Lab haben wir aus
				Gesprächen mit zivilgesellschaftlichen Akteuren verschiedene
				Bedarfe im Umgang mit dieser Methode identifiziert, die uns dazu
				bewegt haben, sie in dieser Werkstattbox zu behandeln.
			</p>
		</section>
	
		<section>
			<SurveyPhases phases={phases} markers={markers} client:load />
		</section>
		<section>
			<p>
				Eine Beobachtung, die wir in der Vergangenheit gemacht haben,
				betrifft die konzeptuelle und allgemeine Einbettung von
				Umfragen: oft wird nicht bis zur Auswertung und darüber hinaus
				gedacht und es fehlt ein Anknüpfen an Best Practices und
				vorhandene Standards. In dieser Werkstattbox haben wir Wissen
				zusammengestellt und begleitende Tools entwickelt, die alle
				Phasen einer Umfrage, von der Konzeption bis zur Auswertung,
				abbildet. Deswegen folgt diese Wissenssammlungen dem obigen
				<b>Modell der Phasen einer Umfrage</b> und stellt Standards vor, die Umfragen unabhängig
				von Tools abbilden können.
			</p>
			<p>
				Mit unserem Modell verbunden ist ein Ansatz, wie man Umfragen
				unabhängig von bestimmten Tools konzipieren, durchführen und
				auswerten kann.
			</p>
		</section>
	</body>
</Layout>

<style>
	section {
		margin-top: 2.5rem;
	}

	.logo-container {
		margin-top: 1rem;
		padding-top: 1rem;
		margin-bottom: 2.5rem;
		background-color: var(--color-tertiary);
		border-radius: 2rem;
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
	}

	.logo-container :global(svg) {
		padding-bottom: 3.5rem;
		padding-top: 3.5rem;
		width: 100%;
		max-width: 600px;
		height: auto;
	}

	@media (max-width: 768px) {
		.logo-container :global(svg) {
			max-width: 100%;
			padding: 1rem;
			padding-bottom: 0.5rem;
		}

		.logo-container {
			margin-top: 3rem;
			margin-bottom: 1rem;
			margin-left: 1rem;
			margin-right: 1rem;
		}
	}
</style>
