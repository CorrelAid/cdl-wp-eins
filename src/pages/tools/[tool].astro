---
import Layout from "../../lib/layouts/Layout.astro";
import toc from "@lib/toc.json";

export function getStaticPaths() {
    const seen = new Set<string>();
    return toc.tools
        .filter((tool) => {
            if (seen.has(tool.id)) return false;
            seen.add(tool.id);
            return true;
        })
        .map((tool) => ({
            params: { tool: tool.id },
            props: { tool },
        }));
}

const { tool } = Astro.props;

const snippets = import.meta.glob<{ default: string }>(
    "/src/content/snippets/*/*.html",
    { query: "?raw", import: "default", eager: true }
);

const lang = "de"; // Default to German
const snippetKey = `/src/content/snippets/${tool.id}/${lang}.html`;
const snippetHtml: string = snippets[snippetKey] ?? "";
---

<Layout title={tool.label}>
    <div class="tool-page">
        {snippetHtml && <div class="tool-description" set:html={snippetHtml} />}
        <a
            href={tool.href}
            target="_blank"
            rel="noopener noreferrer"
            class="tool-button"
        >
            {tool.label} öffnen
            <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
            >
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                <polyline points="15 3 21 3 21 9"></polyline>
                <line x1="10" y1="14" x2="21" y2="3"></line>
            </svg>
        </a>
    </div>
</Layout>

<style>
    .tool-page {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .tool-description :global(section) {
        margin: 0;
    }

    .tool-button {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.6rem 1.2rem;
        background-color: var(--color-primary);
        color: var(--color-white);
        text-decoration: none;
        border-radius: 4px;
        font-weight: 600;
        transition: background-color 0.2s ease;
        align-self: flex-start;
    }

    .tool-button:hover {
        background-color: var(--color-text-primary-darker);
    }

    .tool-button svg {
        width: 14px;
        height: 14px;
        flex-shrink: 0;
    }
</style>
