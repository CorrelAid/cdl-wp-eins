---
import Layout from "../../lib/layouts/Layout.astro";
import toc from "@lib/toc.json";
import ContentBox from "@components/ContentBox.astro";

const snippets = import.meta.glob<string>(
    "/src/content/snippets/*/*.html",
    { query: "?raw", import: "default", eager: true }
);

const lang = "de"; // Default to German
const seen = new Set<string>();
const tools = toc.tools
    .filter((t) => { if (seen.has(t.id)) return false; seen.add(t.id); return true; })
    .map((t) => ({ ...t, snippetHtml: snippets[`/src/content/snippets/${t.id}/${lang}.html`] ?? "" }));

// Group CDL tools by section
const toolSections = toc.toolSections.map(section => ({
    ...section,
    tools: tools.filter(t => (t as any).section === section.id),
}));
const unsectioned = tools.filter(t => !(t as any).section);
---

<Layout title="Tools" teaser="Open-Source-Tools und Ressourcen für verschiedene Phasen einer Umfrage.">
    <div class="tool-list">
        {toolSections.map(section => section.tools.length > 0 && (
            <div class="tool-section">
                <h2 class="tool-section-title">{section.label}</h2>
                {section.tools.map((tool) => (
                    <div class="tool-entry" id={tool.id}>
                        <ContentBox>
                            <Fragment slot="header">
                                {tool.type === "app" ? (
                                    <svg class="tool-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                        <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
                                        <line x1="8" y1="21" x2="16" y2="21"></line>
                                        <line x1="12" y1="17" x2="12" y2="21"></line>
                                    </svg>
                                ) : tool.type === "document" ? (
                                    <svg class="tool-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                                        <polyline points="14 2 14 8 20 8"></polyline>
                                        <line x1="16" y1="13" x2="8" y2="13"></line>
                                        <line x1="16" y1="17" x2="8" y2="17"></line>
                                    </svg>
                                ) : (
                                    <svg class="tool-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                        <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
                                        <polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
                                        <line x1="12" y1="22.08" x2="12" y2="12"></line>
                                    </svg>
                                )}
                                {tool.type === "document" ? (
                                    <span class="tool-name">{tool.label}</span>
                                ) : (
                                    <a href={tool.href} target="_blank" rel="noopener noreferrer" class="tool-name">
                                        {tool.label}
                                        <svg class="external-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                                            <polyline points="15 3 21 3 21 9"></polyline>
                                            <line x1="10" y1="14" x2="21" y2="3"></line>
                                        </svg>
                                    </a>
                                )}
                            </Fragment>
                            {tool.snippetHtml && <div class="tool-snippet" set:html={tool.snippetHtml} />}
                        </ContentBox>
                        <a href={`#${tool.id}`} class="anchor-link" aria-label="Link to this tool">#</a>
                    </div>
                ))}
            </div>
        ))}
        {unsectioned.map((tool) => (
            <div class="tool-entry" id={tool.id}>
                <ContentBox>
                    <Fragment slot="header">
                        {tool.type === "app" ? (
                            <svg class="tool-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
                                <line x1="8" y1="21" x2="16" y2="21"></line>
                                <line x1="12" y1="17" x2="12" y2="21"></line>
                            </svg>
                        ) : (
                            <svg class="tool-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
                                <polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
                                <line x1="12" y1="22.08" x2="12" y2="12"></line>
                            </svg>
                        )}
                        <a href={tool.href} target="_blank" rel="noopener noreferrer" class="tool-name">
                            {tool.label}
                            <svg class="external-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                                <polyline points="15 3 21 3 21 9"></polyline>
                                <line x1="10" y1="14" x2="21" y2="3"></line>
                            </svg>
                        </a>
                    </Fragment>
                    {tool.snippetHtml && <div class="tool-snippet" set:html={tool.snippetHtml} />}
                </ContentBox>
                <a href={`#${tool.id}`} class="anchor-link" aria-label="Link to this tool">#</a>
            </div>
        ))}

        {toc.externalToolSections.map(section => (
            <div class="tool-section">
                <h2 class="tool-section-title">{section.label}</h2>
                <div class="external-links-grid">
                    {section.links.map(link => (
                        <a href={link.href} target="_blank" rel="noopener noreferrer" class="external-link-card">
                            <span class="external-link-name">
                                {link.label}
                                <svg class="external-icon-sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                                    <polyline points="15 3 21 3 21 9"></polyline>
                                    <line x1="10" y1="14" x2="21" y2="3"></line>
                                </svg>
                            </span>
                            <span class="external-link-desc">{link.description}</span>
                        </a>
                    ))}
                </div>
            </div>
        ))}
    </div>
</Layout>

<script>
    function clearActive() {
        document.querySelectorAll('.tool-entry.active').forEach(el => el.classList.remove('active'));
    }

    function scrollToItem(id: string) {
        const el = document.getElementById(id);
        if (!el) return;
        el.scrollIntoView({ behavior: 'smooth', block: 'start' });
        clearActive();
        el.classList.add('active');
        if (history.pushState) {
            history.pushState(null, '', `#${id}`);
        } else {
            window.location.hash = id;
        }
    }

    function init() {
        document.querySelectorAll('.anchor-link').forEach(link => {
            link.addEventListener('click', (e) => {
                e.preventDefault();
                const id = (link as HTMLAnchorElement).getAttribute('href')!.slice(1);
                scrollToItem(id);
            });
        });

        if (window.location.hash) {
            setTimeout(() => scrollToItem(window.location.hash.slice(1)), 100);
        }

        window.addEventListener('popstate', () => {
            if (window.location.hash) {
                clearActive();
                const el = document.getElementById(window.location.hash.slice(1));
                if (el) {
                    el.classList.add('active');
                    el.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            } else {
                clearActive();
            }
        });
    }

    document.addEventListener('astro:page-load', init);
    init();
</script>

<style>
    .tool-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        margin: 1rem 0;
    }

    .tool-section {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .tool-section-title {
        font-size: 1rem;
        font-family: var(--font-family-mono);
        font-weight: var(--font-weight-bold);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--color-text-primary);
        opacity: 0.6;
        margin: 0.5rem 0 0;
        padding-bottom: 0.25rem;
        border-bottom: 1px solid currentColor;
    }

    .tool-entry {
        position: relative;
    }

    .tool-entry.active :global(.content-box) {
        box-shadow: inset -8px 0 0 0 var(--color-secondary);
    }

    .anchor-link {
        position: absolute;
        top: 0.5rem;
        right: 0.75rem;
        opacity: 0;
        font-size: 14px;
        font-weight: bold;
        color: var(--color-secondary);
        text-decoration: none;
        transition: opacity 0.2s ease;
    }

    .tool-entry:hover .anchor-link,
    .tool-entry.active .anchor-link {
        opacity: 1;
    }

    .tool-icon {
        width: 16px;
        height: 16px;
        flex-shrink: 0;
    }

    .tool-name {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        font-family: var(--font-family-mono);
        font-size: 0.9rem;
        font-weight: var(--font-weight-bold);
        color: var(--color-text-primary);
        text-decoration: none;
    }

    .tool-name:hover {
        text-decoration: underline;
    }

    .external-icon {
        width: 12px;
        height: 12px;
        flex-shrink: 0;
        opacity: 0.6;
    }

    .tool-name:hover .external-icon {
        opacity: 1;
    }

    .tool-snippet :global(section) { margin: 0; }
    .tool-snippet :global(p) { margin: 0; font-size: 0.9rem; }
    .tool-snippet :global(ul) { margin: 0; font-size: 0.9rem; }

    /* External link cards */
    .external-links-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 0.75rem;
    }

    .external-link-card {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
        padding: 0.75rem 1rem;
        border: var(--dimension-border-width) solid var(--color-text-primary);
        border-radius: var(--radius-lg);
        text-decoration: none;
        transition: background 0.15s;
        background: var(--color-white);
    }

    .external-link-card:hover {
        background: var(--color-tertiary);
    }

    .external-link-name {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        font-family: var(--font-family-mono);
        font-size: 0.85rem;
        font-weight: var(--font-weight-bold);
        color: var(--color-text-primary);
    }

    .external-icon-sm {
        width: 11px;
        height: 11px;
        opacity: 0.6;
        flex-shrink: 0;
    }

    .external-link-card:hover .external-icon-sm {
        opacity: 1;
    }

    .external-link-desc {
        font-size: 0.8rem;
        color: var(--color-text-primary);
        opacity: 0.75;
        line-height: 1.4;
    }
</style>
