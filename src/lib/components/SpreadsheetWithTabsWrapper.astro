<!--
This wrapper component handles the SpreadsheetWithTabs Svelte component
to ensure proper client-side hydration in MDX
-->

---
import SpreadsheetWithTabs from "./SpreadsheetWithTabs.svelte";

interface Props {
  worksheets: Array<{
    id: string;
    title: string;
    data: Array<Array<string>>;
    headers?: string[];
  }>;
  activeTab?: number;
}

const { worksheets, activeTab } = Astro.props;
---

<SpreadsheetWithTabs client:load worksheets={worksheets} activeTab={activeTab} />