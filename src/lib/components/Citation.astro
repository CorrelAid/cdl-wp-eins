---
import { getLiveCollection } from "astro:content";

interface Props {
    /**
     * Zotero key(s) of the item(s) to cite
     */
    key?: string | string[];

    /**
     * DOI(s) of the item(s) to cite
     */
    doi?: string | string[];

    /**
     * Citation mode/style
     * - 'na': "Author (Year)"
     * - 'pa': "(Author, Year)"
     */
    mode?: 'na' | 'pa';

    /**
     * Whether to include page numbers (if available)
     */
    includePages?: boolean;

    /**
     * Page numbers to cite (if includePages is true)
     */
    pages?: string;
}

const { key, doi, mode = 'pa', includePages = false, pages } = Astro.props;

if (!key && !doi) {
    console.warn("Citation component requires either a 'key' or a 'doi' prop.");
}

// Normalize to arrays
const keys = key ? (Array.isArray(key) ? key : [key]) : [];
const dois = doi ? (Array.isArray(doi) ? doi : [doi]) : [];

// Get literature from live collection
const { entries: literature, error } = await getLiveCollection("literature");

if (error) {
    console.error("Error loading literature collection:", error);
}

// Find item by DOI (checks both DOI field and extra field)
function findByDoi(doiValue: string) {
    return literature?.find(item => {
        if (item.data.DOI === doiValue) return true;
        if (item.data.extra) {
            const extraDoi = item.data.extra.match(/^DOI:\s*(.+)$/m);
            if (extraDoi && extraDoi[1].trim() === doiValue) return true;
        }
        return false;
    });
}

// Resolve all cited items
interface CitedEntry {
    item: any;
    identifier: string;
}

const citedItems: CitedEntry[] = [];
for (const k of keys) {
    const found = literature?.find(item => item.id === k);
    if (found) citedItems.push({ item: found, identifier: k });
    else console.warn(`No literature item found with key: ${k}`);
}
for (const d of dois) {
    const found = findByDoi(d);
    if (found) citedItems.push({ item: found, identifier: d });
    else console.warn(`No literature item found with DOI: ${d}`);
}

// Helper function to format authors for APA style
function formatAuthors(creators: Array<{name: string, lastName?: string}>): string {
    if (!creators || creators.length === 0) return '';

    const getName = (creator: {name: string, lastName?: string}) => creator.lastName || creator.name;

    if (creators.length === 1) {
        return getName(creators[0]);
    }

    if (creators.length === 2) {
        return `${getName(creators[0])} & ${getName(creators[1])}`;
    }

    return `${getName(creators[0])} et al.`;
}

// Helper function to format year
function formatYear(date: string): string {
    if (!date) return '';
    const yearMatch = date.match(/(\d{4})/);
    return yearMatch ? yearMatch[1] : date;
}

// Build per-item citation data
interface CitationPart {
    authors: string;
    year: string;
    link: string;
    text: string;
}

const parts: CitationPart[] = citedItems.map(({ item }) => {
    const { creators, date } = item.data;
    const authors = formatAuthors(creators);
    const year = formatYear(date);
    const link = `/literature#${item.id}`;
    return { authors, year, link, text: `${authors}, ${year}` };
});

// Fallback if nothing was found
const hasCitations = parts.length > 0;
const citationClass = !hasCitations ? "citation-fallback"
    : mode === 'na' ? "na-citation" : "pa-citation";
---

{!hasCitations ? (
    <span class={`citation ${citationClass}`}>[Citation not available]</span>
) : mode === 'na' ? (
    <span class={`citation ${citationClass}`} data-citation-mode={mode}>
        {parts.map((p, i) => (
            <>{i > 0 && '; '}{p.authors} (<a href={p.link} class="literature-link na-year" aria-label="View full citation">{p.year}⤴</a>)</>
        ))}
    </span>
) : (
    <span class={`citation ${citationClass}`} data-citation-mode={mode}>
        ({parts.map((p, i) => (
            <>{i > 0 && '; '}<a href={p.link} class="literature-link" aria-label="View full citation">{p.text}⤴</a></>
        ))})
    </span>
)}

<style>
    .citation {
        font-family: var(--font-sans);
        color: var(--color-text);
        font-size: 0.95em;
        position: relative;
        display: inline;
    }
    
    .literature-link {
        color: inherit;
        text-decoration: none;
        font-weight: normal;
        border-bottom: none; /* Remove underline */
        position: relative;
    }
    
    .literature-link:hover {
        color: var(--color-accent);
        text-decoration: underline;
    }
    
    /* Link symbol styling */
    .link-symbol {
        font-size: 1em;
        vertical-align: middle;
        margin-left: 0.3em;
        color: var(--color-accent);
        font-weight: bold;
        display: inline-block;
        transform: rotate(45deg);
    }
    
    .literature-link:hover .link-symbol {
        color: var(--color-text-primary);
        text-decoration: none;
    }
    
    /* For na citations, make the symbol smaller */
    .na-year .link-symbol {
        font-size: 0.9em;
        vertical-align: super;
        margin-left: 0.2em;
    }
    
    .citation-fallback {
        color: var(--color-text-secondary);
        font-style: italic;
    }
    
    .apa-full-citation {
        display: block;
        margin: 0.5em 0;
        padding: 0.5em;
        background-color: var(--color-surface-1);
        border-radius: 4px;
        font-size: 0.9em;
        line-height: 1.5;
    }
    
    .apa-full-citation em {
        font-style: italic;
        color: var(--color-text-secondary);
    }
    
    /* Style for na year links */
    .literature-link.na-year {
        color: inherit;
        font-weight: normal;
    }
    
    .literature-link.na-year:hover {
        color: var(--color-accent);
    }
</style>