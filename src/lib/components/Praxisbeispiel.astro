---
import ContentBox from "./ContentBox.astro";
---

<aside>
    <ContentBox expandable>
        <Fragment slot="header">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M9 18h6"/>
                <path d="M10 22h4"/>
                <path d="M12 2a7 7 0 0 1 7 7c0 2.5-1.3 4.7-3.3 6l-.7.4V18H9v-2.6l-.7-.4A7 7 0 0 1 12 2z"/>
            </svg>
            <span class="praxisbeispiel-label">Praxisbeispiel</span>
        </Fragment>
        <slot />
    </ContentBox>
</aside>

<style>
    aside {
        margin: var(--spacing-xl) 0;
        counter-increment: praxisbeispiel;
    }

    .praxisbeispiel-label::after {
        content: " " counter(praxisbeispiel);
    }
</style>
