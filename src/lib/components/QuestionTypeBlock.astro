---
import { Tabs } from "@correlaid/cdl-design";
import { codeToHtml } from "shiki";
import { EXAMPLES_API_URL } from "astro:env/server";

interface Props {
    exampleId: string;
    limesurveySrc?: string;
    koboSrc?: string;
}

const { exampleId, limesurveySrc: limesurveySrcProp, koboSrc: koboSrcProp } = Astro.props;

const response = await fetch(`${EXAMPLES_API_URL}/api/examples/${exampleId}`);
if (!response.ok) {
    throw new Error(`Failed to fetch example "${exampleId}": ${response.status} ${response.statusText}`);
}
const example = await response.json();

const xlsform = example.xlsform;
const ddiXml: string | undefined = example.ddi;
const limesurveySrc: string | undefined = limesurveySrcProp ?? example.limesurveySrc;
const koboSrc: string | undefined = koboSrcProp ?? example.koboSrc;

// Build XLSForm HTML — stacked sheet cards
function escapeAttr(str: string): string {
    return str.replace(/&/g, "&amp;").replace(/"/g, "&quot;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
}

function buildSheetCard(sheetName: string, rows: Record<string, string>[]) {
    if (!rows || rows.length === 0) return "";
    const headers = [...new Set(rows.flatMap(r => Object.keys(r)))];
    const headerCells = headers.map(h => `<th>${h}</th>`).join("");
    const bodyRows = rows.map(row =>
        `<tr>${headers.map(h => `<td>${row[h] ?? ""}</td>`).join("")}</tr>`
    ).join("");

    const tsv = [headers.join("\t"), ...rows.map(row => headers.map(h => row[h] ?? "").join("\t"))].join("\n");

    return `<div class="qt-card">
    <div class="qt-card-header">
        <span class="qt-sheet-tab">${sheetName}</span>
        <button class="qt-copy-btn" data-copy="${escapeAttr(tsv)}">Copy</button>
    </div>
    <div class="qt-card-body">
        <table class="qt-table">
            <thead><tr>${headerCells}</tr></thead>
            <tbody>${bodyRows}</tbody>
        </table>
    </div>
</div>`;
}

let xlsHtml = buildSheetCard("survey", xlsform.survey);
if (xlsform.choices && xlsform.choices.length > 0) {
    xlsHtml += buildSheetCard("choices", xlsform.choices);
}

// Build DDI HTML
const ddiHtml = ddiXml
    ? `<div class="qt-card"><div class="qt-card-header"><span class="qt-sheet-tab">DDI Codebook</span><button class="qt-copy-btn" data-copy="${escapeAttr(ddiXml.trim())}">Copy</button></div><div class="qt-card-body">${await codeToHtml(ddiXml.trim(), { lang: "xml", theme: "github-light" })}</div></div>`
    : null;

// Build image tab content
const placeholderHtml = `<div class="qt-card"><div class="qt-card-body"><div class="qt-placeholder">Screenshot folgt</div></div></div>`;

const lsHtml = limesurveySrc
    ? `<div class="qt-card"><div class="qt-card-body"><img src="${limesurveySrc}" alt="LimeSurvey" class="qt-img" /></div></div>`
    : placeholderHtml;

const koboHtml = koboSrc
    ? `<div class="qt-card"><div class="qt-card-body"><img src="${koboSrc}" alt="KoboToolbox" class="qt-img" /></div></div>`
    : placeholderHtml;

const tabs = [
    { title: "XLSForm", content: xlsHtml },
    ...(ddiHtml ? [{ title: "DDI XML", content: ddiHtml }] : []),
    { title: "LimeSurvey", content: lsHtml },
    { title: "KoboToolbox", content: koboHtml },
];
---

<Tabs client:load tabs={tabs} expandLabel="Mehr anzeigen" collapseLabel="Weniger anzeigen" />

<script>
    document.addEventListener("click", (e) => {
        const btn = (e.target as HTMLElement).closest(".qt-copy-btn") as HTMLButtonElement | null;
        if (!btn) return;
        const text = btn.dataset.copy;
        if (!text) return;
        navigator.clipboard.writeText(text).then(() => {
            const original = btn.textContent;
            btn.textContent = "Copied!";
            setTimeout(() => { btn.textContent = original; }, 2000);
        });
    });
</script>

<style is:global>
    .qt-card {
        background: var(--color-white);
        border: var(--dimension-border-width) solid var(--color-text-primary);
        border-radius: var(--radius-lg);
        overflow: hidden;
        margin-bottom: var(--spacing-base);
    }

    .qt-card:last-child {
        margin-bottom: 0;
    }

    .qt-card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: var(--spacing-xs) var(--spacing-base);
        border-bottom: var(--dimension-border-width) solid var(--color-text-primary);
    }

    .qt-sheet-tab {
        font-weight: var(--font-weight-semibold);
        font-size: 0.9rem;
        color: var(--color-text-primary);
    }

    .qt-copy-btn {
        padding: 0;
        background: none;
        border: none;
        color: var(--color-text-primary);
        font-size: 0.75rem;
        font-family: var(--font-family-body);
        cursor: pointer;
        opacity: 0.4;
        transition: opacity 0.15s;
    }

    .qt-copy-btn:hover {
        opacity: 1;
    }

    .qt-card-body {
        overflow-x: auto;
    }

    .qt-card-body pre {
        margin: 0 !important;
        border-radius: 0 !important;
        padding: var(--spacing-base) !important;
    }

    .qt-table {
        width: 100%;
        border-collapse: collapse;
        margin: 0;
    }

    .qt-table th {
        padding: var(--dimension-table-padding);
        text-align: left;
        font-family: var(--font-family-mono);
        font-weight: var(--font-weight-medium);
        font-size: 0.9rem;
        color: var(--color-text-primary);
        background: transparent;
        border-bottom: var(--dimension-border-width) solid var(--color-text-primary);
    }

    .qt-table td {
        padding: var(--dimension-table-padding);
        font-size: 0.9rem;
        color: var(--color-text-primary);
        background: var(--color-white);
        border: none;
        border-bottom: 1px solid rgba(134, 24, 95, 0.12);
    }

    .qt-table tbody tr:last-child td {
        border-bottom: none;
    }

    .qt-placeholder {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 120px;
        color: var(--color-text-primary);
        font-style: italic;
        opacity: 0.5;
    }

    .qt-img {
        max-width: 100%;
        display: block;
    }
</style>
