---
import { getCollection } from "astro:content";
import "@styles/gen_tokens.css";
import "@styles/main.css";
import toc from "@lib/toc.json";
import SideNav from "@components/SideNav.svelte";
import TitleLine from "@components/TitleLine.svelte";
import BaseHead from "@components/BaseHead.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import { ClientRouter } from "astro:transitions";

const { title, teaser, line = true } = Astro.props;
const allPages = await getCollection("pages");

// Create a map of id (filename) to page data for easy lookup
const pageMap = Object.fromEntries(
    allPages.map(page => [page.id, page])
);

// Build nested structure from toc.json
function buildNavStructure(tocArray: any[]): any[] {
    return tocArray.map((item: any) => {
        if (typeof item === 'string') {
            // Special case for quellen page which is not in content collection
            if (item === 'quellen') {
                return {
                    slug: item,
                    page: {
                        data: {
                            tocTitle: 'Quellen',
                            teaser: 'Browse our research quellen'
                        }
                    }
                };
            }
            return { slug: item, page: pageMap[item] };
        } else if (typeof item === 'object' && item.label && item.children) {
            // Section with explicit label and children array
            const slug = item.label;
            const page = pageMap[slug];
            return {
                slug: slug,
                label: item.label,
                page: page,
                children: buildNavStructure(item.children as any[])
            };
        }
        return null;
    }).filter(Boolean);
}

const navStructure = buildNavStructure(toc.sections);

// Recursive component for rendering nav items
function renderNavItem(item: any, level = 0): any {
    const hasChildren = item.children && item.children.length > 0;
    const itemId = `nav-${item.slug}`; 

    return {
        id: itemId,
        slug: item.slug,
        title: item.page ? item.page.data.tocTitle : item.label,
        hasChildren,
        isLink: !!item.page,
        children: hasChildren ? item.children.map((child: any) => renderNavItem(child, level + 1)).filter((x: any) => x !== null) : [],
        level
    };
}

const navItems = navStructure.map((item: any) => renderNavItem(item)).filter((x: any) => x !== null);
const currentPath = Astro.url.pathname;

---

<html lang="en">
    <head>
        <BaseHead title={title} description={teaser} />
        <ClientRouter />
    </head>
    <body>
        <SideNav navItems={navItems} currentPath={currentPath} client:load transition:persist />
        <div class="content-wrapper">
            <main>
                {title && <h1>{title}</h1> }
                {teaser && <p class="teaser">{teaser}</p>}
                {line === true && <TitleLine client:load /> }
                <article>
                    <slot />
                    <!-- your content is injected here -->
                </article>
            </main>
            <Footer />
        </div>
    </body>
    <style>
        
        h1 {
            text-align: center;
        }
        .teaser {
            color: var(--color-text-primary);
            margin-bottom: var(--spacing-lg);
            text-align: center;
        }

        .content-wrapper {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            width: 100%;
            box-sizing: border-box;
        }

        article {
            counter-reset: praxisbeispiel;
        }

        main {
            flex: 1;
            margin-inline: auto;
            max-width: 750px;
            padding: var(--spacing-2xl) var(--spacing-sm) var(--spacing-lg);
            width: 100%;
            box-sizing: border-box;
        }

        @media (min-width: 768px) {
            .content-wrapper {
                padding-left: 250px; /* Use padding instead of margin to ensure background colors fill the space */
            }
        }

    </style>
</html>
